# Port the Fastify server listens on inside the container.
# The compose files publish this port on the host as well.
PORT=31228

# Cloudflare Tunnel token (only used by compose.example.cloudflared.yaml).
# Create a tunnel in the Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → Cloudflared
# Copy the generated token here.
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
